# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git

# Supabase (from supabase.com → Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic (from console.anthropic.com → API Keys)
# This goes in Netlify environment variables - NOT in .env.local
# It is only used server-side in netlify/functions/identify-cards.js
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Pokémon TCG API key (free at pokemontcg.io - raises rate limit)
# VITE_TCG_API_KEY=your-optional-key
